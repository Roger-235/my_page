---
import Layout from './Layout.astro';

interface Props {
  frontmatter: {
    title: string;
    pubDate: string;
    description?: string;
    author?: string;
    tags?: string[];
    image?: { url: string; alt: string };
  };
}

const { frontmatter } = Astro.props;
const date = new Date(frontmatter.pubDate).toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<Layout title={`${frontmatter.title} · 235's blog`}>
  <article class="post animate-in">

    <div class="post-banner">
      <p class="banner-eyebrow">
        Blog
        {frontmatter.tags?.map(tag => <span class="tag mint">#{tag}</span>)}
      </p>
      <h1 class="banner-title">{frontmatter.title}</h1>
      <p class="banner-meta">
        <span>{date}</span>
        {frontmatter.description && <span>· {frontmatter.description}</span>}
        {frontmatter.author && <span>· by {frontmatter.author}</span>}
      </p>
    </div>

    <div class="post-content">
      <slot />
    </div>

    <div class="post-footer">
      <a href="/blog" class="btn btn-outline">← Back to Blog</a>
    </div>

  </article>
</Layout>

<style>
  .post {
    max-width: 680px;
    margin: 0 auto;
  }

  .post-banner {
    padding: 3rem 0 2rem;
    border-bottom: 2px solid var(--text);
    margin-bottom: 2.5rem;
  }

  .banner-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .banner-title {
    font-family: 'EB Garamond', serif;
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 700;
    color: var(--text);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .banner-meta {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    font-size: 1.3rem;
    color: var(--text-muted);
    font-style: italic;
    font-family: 'EB Garamond', serif;
  }

  .post-content {
    line-height: 1.9;
    margin-bottom: 3rem;
    font-size: 1.05rem;
  }

  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3) {
    margin: 2rem 0 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }
  .post-content :global(p) {
    margin-bottom: 1.4rem;
  }
  .post-content :global(strong) {
    color: var(--text);
    font-weight: 700;
  }
  .post-content :global(del) {
    color: var(--text-muted);
  }
  .post-content :global(blockquote) {
    border-left: 3px solid var(--pink);
    padding-left: 1.5rem;
    color: var(--text-muted);
    font-style: italic;
    font-family: 'EB Garamond', serif;
    font-size: 1.15rem;
    margin: 1.5rem 0;
  }

  .post-footer {
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
</style>
