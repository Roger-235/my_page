---
import Layout from './Layout.astro';

interface Props {
  frontmatter: {
    title: string;
    pubDate: string;
    description?: string;
    author?: string;
    tags?: string[];
    image?: { url: string; alt: string };
  };
}

const { frontmatter } = Astro.props;
const date = new Date(frontmatter.pubDate).toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<Layout title={`${frontmatter.title} · 235's blog`}>
  <article class="post animate-in">
    <div class="post-banner">
      <span class="banner-rule">── ✦ ──</span>
      <h1 class="banner-title">{frontmatter.title}</h1>
      <span class="banner-rule">── ✦ ──</span>
    </div>

    <div class="post-header">
      <div class="post-meta">
        <span class="tag">{date}</span>
        {frontmatter.author && <span class="tag lavender">by {frontmatter.author}</span>}
      </div>
      {frontmatter.description && <p class="post-desc">{frontmatter.description}</p>}
      {frontmatter.tags && (
        <div class="post-tags">
          {frontmatter.tags.map(tag => <span class="tag mint">#{tag}</span>)}
        </div>
      )}
    </div>

    <div class="post-content">
      <slot />
    </div>

    <div class="post-footer">
      <a href="/blog" class="btn btn-outline">← back to blog</a>
    </div>
  </article>
</Layout>

<style>
  .post {
    max-width: 680px;
    margin: 0 auto;
  }

  .post-banner {
    height: 200px;
    margin-bottom: 2rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    background: linear-gradient(135deg, #f3dfc8 0%, #e8c89a 50%, #d4a96a 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    position: relative;
    overflow: hidden;
  }

  /* diagonal stripe texture */
  .post-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 12px,
      rgba(255, 255, 255, 0.07) 12px,
      rgba(255, 255, 255, 0.07) 13px
    );
  }

  /* inner frame */
  .post-banner::after {
    content: '';
    position: absolute;
    inset: 10px;
    border: 1px solid rgba(61, 44, 30, 0.15);
    border-radius: calc(var(--radius) - 4px);
  }

  .banner-title {
    font-family: 'EB Garamond', serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    color: rgba(61, 44, 30, 0.72);
    z-index: 1;
    text-align: center;
    padding: 0 2rem;
    line-height: 1.25;
  }

  .banner-rule {
    color: rgba(61, 44, 30, 0.3);
    font-size: 0.8rem;
    letter-spacing: 0.5em;
    z-index: 1;
  }

  .post-header {
    margin-bottom: 2rem;
  }
  .post-meta {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .post-desc {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .post-content {
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2rem 2.5rem;
    box-shadow: var(--shadow);
    line-height: 1.9;
    margin-bottom: 2rem;
  }

  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3) {
    margin: 1.5rem 0 0.75rem;
  }
  .post-content :global(p) {
    margin-bottom: 1.25rem;
  }
  .post-content :global(strong) {
    color: var(--pink);
  }
  .post-content :global(del) {
    color: var(--text-muted);
  }

  .post-footer {
    text-align: center;
  }
</style>
