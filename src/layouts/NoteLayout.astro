---
import Layout from './Layout.astro';

interface Props {
  frontmatter: {
    title: string;
    pubDate: string;
    description?: string;
    tags?: string[];
    updatedDate?: string;
  };
  headings: { depth: number; slug: string; text: string }[];
}

const { frontmatter, headings = [] } = Astro.props;

// Group h3s under their parent h2
type Heading = { depth: number; slug: string; text: string };
type TocItem = Heading & { children: Heading[] };
const tocItems: TocItem[] = [];
for (const h of headings) {
  if (h.depth === 2) {
    tocItems.push({ ...h, children: [] });
  } else if (h.depth === 3 && tocItems.length > 0) {
    tocItems[tocItems.length - 1].children.push(h);
  }
}
const date = new Date(frontmatter.pubDate).toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const updatedDate = frontmatter.updatedDate
  ? new Date(frontmatter.updatedDate).toLocaleDateString('zh-TW', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---
<Layout title={`${frontmatter.title} · 235's notes`}>
  <article class="note animate-in">

    <div class="note-banner">
      <p class="note-eyebrow">
        <a href="/notes" class="back-link">Notes</a>
        {frontmatter.tags?.map(tag => (
          <a href={`/tags/${encodeURIComponent(tag)}`} class="tag mint">#{tag}</a>
        ))}
      </p>
      <h1 class="note-title">{frontmatter.title}</h1>
      <div class="note-meta">
        {frontmatter.description && (
          <p class="meta-desc">{frontmatter.description}</p>
        )}
        <dl class="meta-dates">
          <div class="meta-row">
            <dt>Published</dt>
            <dd>{date}</dd>
          </div>
          {updatedDate && (
            <div class="meta-row">
              <dt>Updated</dt>
              <dd class="updated">{updatedDate}</dd>
            </div>
          )}
        </dl>
      </div>
    </div>

    <div class="note-body">
      {tocItems.length > 0 && (
        <nav class="toc">
          <p class="toc-title">索引</p>
          <ol>
            {tocItems.map((h: TocItem) => (
              <li class="toc-h2">
                <a href={`#${h.slug}`} data-id={h.slug}>{h.text}</a>
                {h.children.length > 0 && (
                  <div class="toc-sub-wrap">
                    <ol class="toc-sub">
                      {h.children.map((sub: Heading) => (
                        <li class="toc-h3">
                          <a href={`#${sub.slug}`} data-id={sub.slug}>{sub.text}</a>
                        </li>
                      ))}
                    </ol>
                  </div>
                )}
              </li>
            ))}
          </ol>
        </nav>
      )}

      <div class="note-content">
        <slot />
      </div>
    </div>

    <div class="note-footer">
      <a href="/notes" class="btn btn-outline">← Back to Notes</a>
    </div>

  </article>
</Layout>


<style>
  .note {
    max-width: 100%;
    margin: 0 auto;
  }

  .note-body {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 700px) {
    .note-body {
      grid-template-columns: 1fr;
    }
  }

  .note-banner {
    padding: 3rem 0 2rem;
    border-bottom: 2px solid var(--text);
    margin-bottom: 2.5rem;
  }

  .note-eyebrow {
    font-family: 'EB Garamond', serif;
    font-size: 1rem;
    font-style: italic;
    color: var(--text-muted);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .back-link {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition);
  }
  .back-link:hover { color: var(--mint); }

  .note-title {
    font-family: 'EB Garamond', serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .note-meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .meta-desc {
    font-family: 'EB Garamond', serif;
    font-size: 1.05rem;
    font-style: italic;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .meta-dates {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    border-left: 2px solid var(--border);
    padding-left: 0.85rem;
  }

  .meta-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }

  .meta-row dt {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--border);
    width: 4.5rem;
    flex-shrink: 0;
  }

  .meta-row dd {
    font-size: 0.82rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }

  .meta-row dd.updated {
    color: var(--mint);
  }

  .toc {
    border-left: 2px solid var(--text-muted);
    padding-left: 1rem;
    position: sticky;
    top: 5rem;
  }

  .toc-title {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .toc ol {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .toc a {
    font-size: 0.82rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition);
    line-height: 1.4;
    display: block;
  }
  .toc a:hover { color: var(--text); }
  .toc a.active {
    color: var(--mint);
  }

  .toc-h2 > a {
    font-weight: 600;
  }

  .toc-sub-wrap {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.25s ease,
      margin-top 0.3s ease;
    margin-top: 0;
  }

  .toc-h2.open > .toc-sub-wrap,
  .toc-h2:hover > .toc-sub-wrap {
    grid-template-rows: 1fr;
    opacity: 1;
    margin-top: 0.25rem;
  }

  .toc-sub {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    overflow: hidden;
    min-height: 0;
  }

  .toc-h3 {
    padding-left: 0.75rem;
  }
  .toc-h3 a {
    font-size: 0.75rem;
  }

  .note-content {
    line-height: 1.85;
  }

  .note-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
    font-family: ui-monospace, 'Cascadia Code', Menlo, Consolas, monospace;
  }

  .note-content :global(th),
  .note-content :global(td) {
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--border);
    text-align: left;
  }

  .note-content :global(th) {
    background: var(--surface);
    font-weight: 700;
    color: var(--text);
  }

  .note-content :global(tr:nth-child(even) td) {
    background: var(--surface);
  }

  .note-content :global(h2) {
    margin: 2rem 0 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--text-muted);
    scroll-margin-top: 5rem;
  }

  .note-content :global(h3) {
    scroll-margin-top: 5rem;
    margin-top: 1.75rem;
    margin-left: 1.5rem;
    font-size: 1.45rem;
    margin-bottom: 0.5rem;
  }

  :global(.h3-content) {
    padding-left: 1.5rem;
  }

  .note-content :global(blockquote) {
    border-left: 3px solid var(--mint);
    padding-left: 1.5rem;
    color: var(--text-muted);
    font-style: italic;
    font-family: 'EB Garamond', serif;
    font-size: 1.15rem;
    margin: 1.5rem 0;
  }

  .note-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .note-eyebrow .tag {
    padding: 0.2rem 0.75rem;
    font-size: 0.6rem;
    text-decoration: none;
    transition: opacity var(--transition);
  }
  .note-eyebrow .tag:hover { opacity: 0.75; }
  .note-eyebrow .tag.mint {
    border: 1px solid var(--mint);
    color: var(--mint);
  }
</style>

<script>
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc a[data-id]');
  if (links.length > 0) {
    const ids = Array.from(links).map(a => a.dataset.id!);
    const headings = ids.map(id => document.getElementById(id)).filter(Boolean) as HTMLElement[];
    const h2Items = document.querySelectorAll<HTMLLIElement>('.toc-h2');

    let active = '';

    const updateActive = () => {
      links.forEach(a => a.classList.toggle('active', a.dataset.id === active));

      // Open the parent h2 li if active id is inside it
      h2Items.forEach(li => {
        const ids = Array.from(li.querySelectorAll<HTMLAnchorElement>('a[data-id]'))
          .map(a => a.dataset.id!);
        li.classList.toggle('open', ids.includes(active));
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            active = entry.target.id;
          }
        }
        updateActive();
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
    );

    headings.forEach(h => observer.observe(h));
  }
</script>
