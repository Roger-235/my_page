---
import Layout from '../layouts/Layout.astro';

const posts = await Astro.glob('./posts/*.md');
posts.sort((a, b) =>
  new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime()
);

const byYear = posts.reduce((acc: Record<string, typeof posts>, post) => {
  const year = new Date(post.frontmatter.pubDate).getFullYear().toString();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));
---
<Layout title="Timeline · 235's blog">
  <section class="tl-page animate-in">

    <div class="page-header">
      <div class="page-eyebrow">Archive</div>
      <h1>Timeline</h1>
      <p class="subtitle">Time stays long enough for those who use it.</p>
    </div>

    {years.map(year => (
      <div class="year-group">
        <div class="year-label">{year}</div>
        <div class="year-posts">
          {byYear[year].map((post: any) => (
            <a href={post.url} class="tl-item">
              <span class="tl-date">
                {new Date(post.frontmatter.pubDate).toLocaleDateString('en', {
                  month: 'short', day: 'numeric'
                })}
              </span>
              <div class="tl-body">
                <p class="tl-title">{post.frontmatter.title}</p>
                {post.frontmatter.description && (
                  <p class="tl-desc">{post.frontmatter.description}</p>
                )}
              </div>
              <span class="tl-arrow">→</span>
            </a>
          ))}
        </div>
      </div>
    ))}

  </section>
</Layout>

<style>
  .tl-page {
    max-width: 680px;
    margin: 0 auto;
  }

  .page-header {
    padding: 2rem 0 2rem;
    border-bottom: 2px solid var(--text);
    margin-bottom: 0;
  }

  .page-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .page-header h1 {
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.75rem;
    font-style: italic;
    font-family: 'EB Garamond', serif;
  }

  /* Year group */
  .year-group {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 0 2rem;
  }

  .year-label {
    padding-top: 1.75rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  .year-posts {
    border-left: 1px solid var(--border);
    position: relative;
  }

  /* Post item */
  .tl-item {
    display: grid;
    grid-template-columns: 4rem 1fr auto;
    gap: 0 1.25rem;
    align-items: start;
    padding: 1.5rem 1.5rem 1.5rem 1.75rem;
    border-bottom: 1px solid var(--border);
    color: inherit;
    text-decoration: none;
    cursor: pointer;
    position: relative;
  }

  .tl-title, .tl-desc, .tl-date {
    transition: transform 1s cubic-bezier(0.34, 1.56, 0.64, 1), color var(--transition);
  }
  .tl-arrow {
    transition: color var(--transition);
  }
  .tl-item:hover .tl-title,
  .tl-item:hover .tl-desc,
  .tl-item:hover .tl-date {
    transform: translateX(14px);
  }

  /* dot */
  .tl-item::before {
    content: '';
    position: absolute;
    left: -4px;
    top: 1.85rem;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--pink);
    border: 2px solid var(--bg);
    box-shadow: 0 0 0 1px var(--pink);
  }

  .tl-item:hover .tl-title { color: var(--pink); }
  .tl-item:hover .tl-arrow { color: var(--pink); }

  .tl-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    padding-top: 0.2rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    line-height: 1.4;
  }

  .tl-title {
    font-family: 'EB Garamond', serif;
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.2rem;
    line-height: 1.3;
  }

  .tl-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .tl-arrow {
    color: var(--border);
    font-size: 1rem;
    padding-top: 0.25rem;
    transition: color var(--transition);
  }

  @media (max-width: 480px) {
    .tl-item {
      grid-template-columns: 3rem 1fr auto;
    }
    .year-group {
      grid-template-columns: 2.5rem 1fr;
    }
  }
</style>
