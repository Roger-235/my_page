---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))] as string[];
  return categories.map(category => ({
    params: { category },
    props: {
      category,
      posts: posts
        .filter(p => p.data.category === category)
        .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()),
    },
  }));
}

const { category, posts } = Astro.props;
---
<Layout title={`${category} · 235's blog`}>
  <section class="chip-page animate-in">

    <div class="page-header">
      <div class="page-eyebrow"><a href="/categories">Categories</a></div>
      <h1>{category}</h1>
      <p class="subtitle">{posts.length} 篇文章</p>
    </div>

    <div class="posts-list">
      {posts.map((post: any) => (
        <a href={`/posts/${post.slug}`} class="post-item">
          <div class="post-date">
            {post.data.pubDate.toLocaleDateString('zh-TW', {
              year: 'numeric', month: 'numeric', day: 'numeric'
            })}
          </div>
          <div class="post-body">
            <h2 class="post-title">{post.data.title}</h2>
            {post.data.description && <p class="post-desc">{post.data.description}</p>}
          </div>
          <span class="post-arrow">→</span>
        </a>
      ))}
    </div>

  </section>
</Layout>

<style>
  .chip-page { max-width: 680px; margin: 0 auto; }
  .page-header {
    padding: 2rem 0 2rem;
    border-bottom: 2px solid var(--text);
    margin-bottom: 0;
  }
  .page-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .page-eyebrow a { color: var(--text-muted); }
  .page-eyebrow a:hover { color: var(--pink); }
  .page-header h1 { margin-bottom: 0.25rem; }
  .subtitle {
    color: var(--text-muted);
    font-size: 0.93rem;
    font-style: italic;
    font-family: 'EB Garamond', serif;
  }
  .posts-list { display: flex; flex-direction: column; }
  .post-item {
    display: grid;
    grid-template-columns: 6.5rem 1fr auto;
    gap: 1.5rem;
    align-items: start;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    color: inherit;
    text-decoration: none;
    cursor: pointer;
  }
  .post-item:hover .post-title { color: var(--pink); }
  .post-item:hover .post-arrow { color: var(--pink); }
  .post-title, .post-desc, .post-date {
    transition: transform 1s cubic-bezier(0.34, 1.56, 0.64, 1), color var(--transition);
  }
  .post-item:hover .post-title,
  .post-item:hover .post-desc,
  .post-item:hover .post-date { transform: translateX(14px); }
  .post-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
    padding-top: 0.3rem;
    letter-spacing: 0.02em;
  }
  .post-title {
    font-family: 'EB Garamond', serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.3rem;
    line-height: 1.3;
  }
  .post-desc { color: var(--text-muted); font-size: 0.88rem; line-height: 1.6; }
  .post-arrow {
    color: var(--border);
    font-size: 1.1rem;
    padding-top: 0.25rem;
    transition: color var(--transition);
  }
  @media (max-width: 480px) {
    .post-item { grid-template-columns: 1fr auto; }
    .post-date { display: none; }
  }
</style>
