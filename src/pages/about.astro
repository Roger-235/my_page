---
import Layout from '../layouts/Layout.astro';

const identity = {
  occupation: "就讀高科大電子工程系一年級",
  hobbies: ["程式設計", "j-pop", "動漫", "遊戲", "電腦", "健身", "腳踏車", "排球", "美股", "基本經濟概論", "哲學", "心理學"],
};

const skillcards = [
  {
    name: "程式設計",
    description: "高三開始接觸程式的一個新手小白，對演算法跟ai的基本概論有興趣，被各位大神電爛之後正在高速成長中...",
  },
  {
    name: "j-pop",
    description: "",
  },
  {
    name: "動漫",
    description: "",
  },
];
---
<Layout title="關於我 · 235's page">
  <section class="about animate-in">

    <div class="about-header">
      
      <h1>About 235</h1>
      <p class="occupation">一個成分複雜的人類...</p>
    </div>


	<div class="section-card">
      <h2>關於 </h2>
      <p>我是 yo，但是似乎 235 更順耳所以也可以叫我 235。</p>
	  <p>目前{identity.occupation}</p>
    </div>

	
    <div class="section-card">
      <h2>關鍵字</h2>
      <div class="tags-wrap">
        {identity.hobbies.map((hobby, i) => (
          <span class={`tag ${i % 3 === 1 ? 'lavender' : i % 3 === 2 ? 'mint' : ''}`}>{hobby}</span>
        ))}
      </div>
      <blockquote class="quote-inline">"對這個世界永遠保持好奇心"</blockquote>
    </div>


    {skillcards.filter(s => s.description).length > 0 && (
      <div class="section-card">
        <h2>技能</h2>
        <div class="skill-grid">
          {skillcards.filter(s => s.description).map(skill => (
            <div class="card skill-card">
              <h3>{skill.name}</h3>
              <p>{skill.description}</p>
            </div>
          ))}
        </div>
      </div>
    )}

  </section>
</Layout>

<style>
  .about {
    max-width: 680px;
    margin: 0 auto;
  }

  .about-header {
    padding: 2.5rem 0 2rem;
    border-bottom: 2px solid var(--text);
    margin-bottom: 0;
  }

  .header-ornament {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    width: fit-content;
  }

  .orn-line {
    display: block;
    width: 40px;
    height: 1px;
    background: var(--border);
  }

  .orn-mark {
    color: var(--pink);
    font-size: 0.9rem;
  }

  .about-header h1 {
    margin-bottom: 0.3rem;
  }

  .occupation {
    color: var(--text-muted);
    font-size: 0.88rem;
    letter-spacing: 0.04em;
  }

  .section-card {
    border-top: 1px solid var(--border);
    padding: 1.75rem 0;
  }

  .section-card h2 {
    font-size: 1.7rem;
    color: var(--text-muted);
    font-weight: 700;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-family: 'Jost', sans-serif;
  }

  .tags-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .quote-inline {
    display: block;
    margin-top: 1.25rem;
    padding-left: 1rem;
    border-left: 2px solid var(--pink);
    color: var(--text-muted);
    font-style: italic;
    font-family: 'EB Garamond', serif;
    font-size: 1.05rem;
  }

  .skill-grid {
    display: grid;
    gap: 1rem;
  }

  .skill-card {
    border-top: 2px solid var(--text) !important;
  }

  .skill-card h3 {
    color: var(--text);
    font-size: 1rem;
    margin-bottom: 0.4rem;
  }

  .skill-card p {
    color: var(--text-muted);
    font-size: 0.93rem;
    line-height: 1.65;
  }

</style>
