---
import Layout from '../layouts/Layout.astro';
---
<Layout title="235's page">
  <section class="hero animate-in">
    <div class="hero-eyebrow">Personal Journal · Since 2026</div>
    <h1 class="hero-title">こんにちは<br /><em class="hero-em">235 です！</em></h1>
    <div class="hero-rule"></div>
    <p class="typewriter" aria-label="235's personal journal"></p>
    <div class="hero-btns">
      <a href="/about/" class="btn btn-primary">Abaut me</a>
      <a href="/blog" class="btn btn-outline">Blog box</a>
    </div>
    <div class="social-links">
      <a href="https://www.instagram.com/6349n_y?igsh=MTNjNzU5aW1ycW10dw==" target="_blank" rel="noopener" class="social-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
        Instagram
      </a>
      <span class="social-sep">·</span>
      <a href="https://github.com/Roger-235" target="_blank" rel="noopener" class="social-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 6rem 1rem 5rem;
    max-width: 640px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .hero-title {
    font-size: clamp(2.8rem, 8vw, 5rem);
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  .hero-em {
    font-style: italic;
    color: var(--pink);
    font-variant-numeric: oldstyle-nums;
  }

  .hero-rule {
    width: 100%;
    height: 1px;
    background: var(--border);
    margin: 0 auto 2rem;
  }

  .typewriter {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 2.75rem;
    min-height: 1.8em;
    font-style: italic;
    font-family: 'EB Garamond', serif;
  }

  .typewriter::after {
    content: '|';
    color: var(--pink);
    animation: blink 0.75s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .hero-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 1rem;
    justify-content: center;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--transition);
    cursor: pointer;
  }
  .social-link svg { flex-shrink: 0; }
  .social-link:hover { color: var(--pink); }

  .social-sep {
    color: var(--border);
    font-size: 1.2rem;
  }
</style>

<script>
  const el = document.querySelector('.typewriter') as HTMLElement;
  const lines = [
    '嗨',
    '初次見面',
    '我是235',
    '一個內向的人',
    '喜歡研究一些酷酷的東西',
    '似乎正在朝著小時候覺得很酷的人前進...',
  ];

  let lineIdx = 0;
  let charIdx = 0;
  let deleting = false;

  function tick() {
    const current = lines[lineIdx];

    if (!deleting) {
      charIdx++;
      el.textContent = current.slice(0, charIdx);
      if (charIdx === current.length) {
        setTimeout(() => { deleting = true; tick(); }, 1800);
        return;
      }
    } else {
      charIdx--;
      el.textContent = current.slice(0, charIdx);
      if (charIdx === 0) {
        deleting = false;
        lineIdx = (lineIdx + 1) % lines.length;
      }
    }

    setTimeout(tick, deleting ? 45 : 90);
  }

  setTimeout(tick, 600);
</script>
