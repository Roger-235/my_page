---
import Layout from '../layouts/Layout.astro';
---
<Layout title="235's page">
  <section class="hero animate-in">
    <div class="hero-deco">✦</div>
    <h1 class="hero-title">こんにちは！<br /><span class="highlight">我是 235</span></h1>
    <p class="hero-sub">就讀高科大電子工程系一年級，對世界保持好奇心的學生</p>
    <blockquote class="quote">"對這個世界永遠保持好奇心"</blockquote>
    <div class="hero-btns">
      <a href="/about/" class="btn btn-primary">關於我 ✿</a>
      <a href="/blog" class="btn btn-outline">看看 blog ✦</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 1rem 5rem;
  }

  .hero-deco {
    font-size: 2.8rem;
    color: var(--pink);
    margin-bottom: 1.5rem;
    display: block;
    animation: float 3.5s ease-in-out infinite;
  }

  .hero-title {
    margin-bottom: 1rem;
    line-height: 1.25;
  }

  .highlight {
    background: linear-gradient(135deg, var(--pink), var(--lavender));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 1.75rem;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }

  .quote {
    display: inline-block;
    padding: 0.9rem 1.75rem;
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid var(--border);
    border-left: 4px solid var(--pink);
    border-radius: var(--radius-sm);
    color: var(--text-muted);
    font-style: italic;
    margin-bottom: 2.5rem;
    box-shadow: var(--shadow);
  }

  .hero-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
