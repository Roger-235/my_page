---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<Layout title="Blog · 235's page">
  <section class="blog animate-in">

    <div class="blog-header">
      <div class="blog-eyebrow">Archive</div>
      <h1>Blog</h1>
      <p class="subtitle">學習筆記 × 生活日常</p>
    </div>

    <div class="posts-list">
      {posts.map(post => (
        <a href={`/posts/${post.slug}`} class="post-item">
          <div class="post-body">
            <h2 class="post-title">{post.data.title}</h2>
            {post.data.description && (
              <p class="post-desc">{post.data.description}</p>
            )}
            {post.data.category && (
              <span class="post-category">{post.data.category}</span>
            )}
          </div>
          <span class="post-arrow">→</span>
        </a>
      ))}
    </div>

  </section>
</Layout>

<style>
  .blog {
    max-width: 680px;
    margin: 0 auto;
  }

  .blog-header {
    padding: 2rem 0 2rem;
    border-bottom: 2px solid var(--text);
    margin-bottom: 0;
  }

  .blog-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .blog-header h1 {
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 0.93rem;
    font-style: italic;
    font-family: 'EB Garamond', serif;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
  }

  .post-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.5rem;
    align-items: start;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    color: inherit;
    text-decoration: none;
    cursor: pointer;
  }
  .post-item:hover .post-title { color: var(--pink); }
  .post-item:hover .post-arrow { color: var(--pink); }

  .post-title, .post-desc {
    transition: transform 1s cubic-bezier(0.34, 1.56, 0.64, 1), color var(--transition);
  }
  .post-arrow {
    transition: color var(--transition);
  }
  .post-item:hover .post-title,
  .post-item:hover .post-desc {
    transform: translateX(14px);
  }

  .post-title {
    font-family: 'EB Garamond', serif;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.3rem;
    line-height: 1.3;
  }

  .post-desc {
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.6;
    margin-bottom: 0.3rem;
  }

  .post-category {
    display: inline-block;
    padding: 0.1rem 0.45rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--lavender);
    color: var(--lavender);
    font-family: 'EB Garamond', serif;
    font-size: 0.9rem;
    font-style: italic;
  }

  .post-arrow {
    color: var(--border);
    font-size: 1.1rem;
    padding-top: 0.25rem;
    transition: color var(--transition);
  }

  @media (max-width: 480px) {
    .post-item {
      grid-template-columns: 1fr auto;
    }
  }
</style>
