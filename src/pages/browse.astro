---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);

const categoryMap = posts.reduce((acc: Record<string, number>, post) => {
  if (post.data.category) {
    acc[post.data.category] = (acc[post.data.category] || 0) + 1;
  }
  return acc;
}, {});

const tagMap = posts.reduce((acc: Record<string, number>, post) => {
  post.data.tags.forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {});

const categories = Object.entries(categoryMap).sort((a, b) => b[1] - a[1]);
const tags = Object.entries(tagMap).sort((a, b) => b[1] - a[1]);
---

<Layout title="Browse · 235's blog">
  <section class="browse animate-in">

    <div class="page-header">
      <div class="page-eyebrow">Index</div>
      <h1>Browse</h1>
    </div>

    <div class="section">
      <h2 class="section-label">Categories</h2>
      <div class="chip-grid">
        {categories.map(([name, count]) => (
          <a href={`/categories/${name}`} class="chip-item lavender">
            <span class="chip-name">{name}</span>
            <span class="chip-count">{count}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="section">
      <h2 class="section-label">Tags</h2>
      <div class="chip-grid">
        {tags.map(([name, count]) => (
          <a href={`/tags/${name}`} class="chip-item mint">
            <span>#</span><span class="chip-name">{name}</span>
            <span class="chip-count">{count}</span>
          </a>
        ))}
      </div>
    </div>

  </section>
</Layout>

<style>
  .browse {
    max-width: 680px;
    margin: 0 auto;
  }

  .page-header {
    padding: 2rem 0 2rem;
    border-bottom: 2px solid var(--text);
    margin-bottom: 2.5rem;
  }

  .page-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .section-label {
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .chip-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .chip-item {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.4rem 1rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: all var(--transition);
  }

  .chip-item.lavender {
    border: 1.5px solid var(--lavender);
    color: var(--lavender);
  }
  .chip-item.lavender:hover {
    background: var(--lavender);
    color: var(--bg);
  }

  .chip-item.mint {
    border: 1.5px solid var(--mint);
    color: var(--mint);
  }
  .chip-item.mint:hover {
    background: var(--mint);
    color: var(--bg);
  }

  .chip-count {
    font-size: 0.7rem;
    opacity: 0.75;
    margin-left: 0.25rem;
  }
</style>
